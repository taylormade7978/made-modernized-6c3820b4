{
  "name": "made-pwa",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "MADE card game — mobile-first React PWA client (VForce360 Track B). Shell-agnostic bundle: runs standalone in a browser and, unchanged, inside a Capacitor native container.",
  "scripts": {
    "dev": "vite",
    "stage:wasm": "node scripts/stage-wasm.mjs",
    "prebuild": "node scripts/stage-wasm.mjs",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "icons": "node scripts/gen-icons.mjs"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2",
    "graphql-ws": "^5.16.0"
  },
  "devDependencies": {
    "@types/node": "^22.7.4",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.2",
    "typescript": "^5.6.2",
    "vite": "^5.4.8",
    "vite-plugin-pwa": "^0.20.5",
    "msw": "^2.4.9",
    "vitest": "^2.1.2"
  }
}
